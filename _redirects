# Public profile pages are served by /u/index.html, which reads the
# username from the URL path. Cloudflare's static asset router only
# matches literal files/folders, so a request for /u/SomeUsername would
# 404 by default. This rewrite (200 = proxy, keeps the URL as-is) sends
# any /u/<username> request to the actual u/index.html page.
/u/:username /u/ 200
